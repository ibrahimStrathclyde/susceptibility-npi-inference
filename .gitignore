# R session artefacts
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rproj

# Stan compiled model objects (auto-regenerated by rstan on first run)
*.o
*.so
*.dll

# Runtime outputs (generated by scripts; reproducible from code)
outputs/figures/
outputs/results/
outputs/stan_fits/

# Keep the outputs directory itself so the folder exists on clone
outputs/.gitkeep

# Saved Stan fit objects (large; not version-controlled)
*.rds

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log
